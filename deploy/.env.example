# SPDX-License-Identifier: AGPL-3.0-or-later
# Copy to deploy/.env and fill in. NEVER commit the filled-in file.
INTRAKTIBLE_TAG=latest
# Postgres password (used by both the app DSN and the postgres container).
POSTGRES_PASSWORD=change-me-strong
# 32-byte encryption key, base64 or hex. Generate: openssl rand -base64 32
# LOSING THIS KEY makes all encrypted-at-rest data permanently unreadable — back it up.
INTRAKTIBLE_ENCRYPTION_KEY=
# Optional: a separate key for connector credentials (falls back to the above if empty).
INTRAKTIBLE_CONNECTOR_SECRET_KEY=
# The first admin credential (a real secret, >=16 chars). Rotate to a managed key,
# then unset this. Without it, configure SSO instead.
INTRAKTIBLE_BOOTSTRAP_API_KEY=
