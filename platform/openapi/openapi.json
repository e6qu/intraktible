{
  "openapi": "3.1.0",
  "info": {
    "title": "intraktible Decision API",
    "version": "0.1.0",
    "description": "The public integration contract for intraktible: execute decision flows, read decision history, manage flows as code, and drive the deployment lifecycle (deploy / promote) for CI/CD. Other administrative endpoints (RBAC, audit, secrets) are out of scope of this document. Authenticate every request with an API key in the X-Api-Key header.",
    "license": { "name": "AGPL-3.0-or-later", "identifier": "AGPL-3.0-or-later" }
  },
  "servers": [{ "url": "/", "description": "This instance" }],
  "security": [{ "ApiKeyAuth": [] }],
  "tags": [
    { "name": "decide", "description": "Execute published flows (the hot path)." },
    { "name": "decisions", "description": "Read recorded decision history." },
    { "name": "flows", "description": "List, create, read, and import flows." },
    { "name": "deployments", "description": "Deploy and promote versions across environments (CI/CD)." },
    { "name": "identity", "description": "Caller introspection." }
  ],
  "paths": {
    "/v1/flows/{slug}/{env}/decide": {
      "post": {
        "tags": ["decide"],
        "summary": "Execute a flow",
        "description": "Runs the live version of the flow (champion, or A/B challenger) in the given environment against the supplied data and records the decision.",
        "parameters": [
          { "$ref": "#/components/parameters/Slug" },
          { "$ref": "#/components/parameters/Env" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DecideRequest" } } }
        },
        "responses": {
          "200": {
            "description": "The decision was recorded (a flow whose logic errors is a recorded 'failed' decision, not an HTTP error).",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DecideResponse" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows/{slug}/{env}/decide/batch": {
      "post": {
        "tags": ["decide"],
        "summary": "Batch-execute a flow over a dataset",
        "description": "Runs each row of a dataset through the recorded decide path (capped at 500 rows).",
        "parameters": [
          { "$ref": "#/components/parameters/Slug" },
          { "$ref": "#/components/parameters/Env" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BatchDecideRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Per-row decisions plus a summary.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BatchDecideResponse" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/decisions": {
      "get": {
        "tags": ["decisions"],
        "summary": "List recorded decisions",
        "parameters": [
          { "name": "slug", "in": "query", "schema": { "type": "string" }, "description": "Filter by flow slug." },
          { "name": "limit", "in": "query", "schema": { "type": "integer" }, "description": "Maximum rows to return." }
        ],
        "responses": {
          "200": {
            "description": "A page of decisions, newest first.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DecisionList" } } }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/decisions/{decision_id}": {
      "get": {
        "tags": ["decisions"],
        "summary": "Read one decision",
        "parameters": [
          { "name": "decision_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "The decision record with its node-level trace.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Decision" } } }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows": {
      "get": {
        "tags": ["flows"],
        "summary": "List flows",
        "responses": {
          "200": {
            "description": "All flows for the caller's tenant.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowList" } } }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      },
      "post": {
        "tags": ["flows"],
        "summary": "Create a flow",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateFlowRequest" } } }
        },
        "responses": {
          "201": {
            "description": "The flow was created.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateFlowResponse" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows/{flow_id}": {
      "get": {
        "tags": ["flows"],
        "summary": "Read a flow",
        "parameters": [{ "$ref": "#/components/parameters/FlowID" }],
        "responses": {
          "200": {
            "description": "The flow with its versions and deployments.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Flow" } } }
          },
          "401": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows/import": {
      "post": {
        "tags": ["flows"],
        "summary": "Import a flow as code",
        "description": "Upserts a flow from an exported document: creates it when the slug is new, otherwise publishes the graph as a new version. Re-importing identical content is a no-op (200, published=false).",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowImport" } } }
        },
        "responses": {
          "200": {
            "description": "No change (the live latest version already matches).",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowImportResult" } } }
          },
          "201": {
            "description": "A flow and/or version was written.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowImportResult" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows/import-bundle": {
      "post": {
        "tags": ["flows"],
        "summary": "Import many flows at once",
        "description": "Imports a bundle of flow-as-code documents (a GitOps repo). Best-effort: a failing flow is reported in its result rather than aborting the rest.",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowBundle" } } }
        },
        "responses": {
          "200": {
            "description": "A per-flow report with rollup counts.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/FlowBundleResult" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows/{flow_id}/deployments": {
      "post": {
        "tags": ["deployments"],
        "summary": "Deploy a version to an environment",
        "description": "Makes a published version live in an environment (a direct deploy). Requires the approver role.",
        "parameters": [{ "$ref": "#/components/parameters/FlowID" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DeployRequest" } } }
        },
        "responses": {
          "201": { "description": "The version is live in the environment." },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/flows/{flow_id}/promote": {
      "post": {
        "tags": ["deployments"],
        "summary": "Promote a live version up the environment chain",
        "description": "Ships the live version of `from` up to `to`. A non-production target deploys directly; production opens a maker-checker request. A promotion gate (firing monitors / failing assertions) can block it unless `force` is allowed for the stage. Requires the approver role.",
        "parameters": [{ "$ref": "#/components/parameters/FlowID" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PromoteRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Promoted directly, or a maker-checker request was opened (pending).",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PromoteResult" } } }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" },
          "403": { "$ref": "#/components/responses/Error" },
          "409": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/v1/me": {
      "get": {
        "tags": ["identity"],
        "summary": "The authenticated caller",
        "responses": {
          "200": {
            "description": "The resolved identity, scope, and role.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Me" } } }
          },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": { "type": "apiKey", "in": "header", "name": "X-Api-Key" }
    },
    "parameters": {
      "Slug": { "name": "slug", "in": "path", "required": true, "schema": { "type": "string" }, "description": "The flow's slug." },
      "Env": { "name": "env", "in": "path", "required": true, "schema": { "type": "string", "enum": ["sandbox", "staging", "production"] }, "description": "The deployment environment." },
      "FlowID": { "name": "flow_id", "in": "path", "required": true, "schema": { "type": "string" } }
    },
    "responses": {
      "Error": {
        "description": "An error.",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "error": { "type": "string", "description": "A human-readable message." } }
      },
      "DecideRequest": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": { "type": "object", "description": "The decision input, validated against the version's input schema." },
          "entity_type": { "type": "string", "description": "Optional Context Layer entity type; its features are injected under 'features'." },
          "entity_id": { "type": "string", "description": "Optional Context Layer entity id." }
        }
      },
      "DecideResponse": {
        "type": "object",
        "properties": {
          "decision_id": { "type": "string" },
          "status": { "type": "string", "enum": ["completed", "failed"] },
          "data": { "type": "object", "description": "The flow output (on success)." },
          "disposition": { "type": "string", "description": "The policy's automated outcome, when a policy is bound." },
          "error": { "type": "string", "description": "The failure reason (on failure)." }
        }
      },
      "BatchDecideRequest": {
        "type": "object",
        "required": ["dataset"],
        "properties": {
          "dataset": { "type": "array", "items": { "type": "object" }, "description": "Up to 500 input rows." },
          "entity_type": { "type": "string" },
          "entity_id": { "type": "string" }
        }
      },
      "BatchDecideResponse": {
        "type": "object",
        "properties": {
          "summary": { "type": "object", "description": "Totals across the batch." },
          "results": { "type": "array", "items": { "type": "object" }, "description": "Per-row decision results." }
        }
      },
      "DecisionList": {
        "type": "object",
        "properties": { "decisions": { "type": "array", "items": { "$ref": "#/components/schemas/Decision" } } }
      },
      "Decision": {
        "type": "object",
        "properties": {
          "decision_id": { "type": "string" },
          "slug": { "type": "string" },
          "version": { "type": "integer" },
          "environment": { "type": "string" },
          "status": { "type": "string", "enum": ["completed", "failed"] },
          "disposition": { "type": "string" },
          "reason_codes": { "type": "array", "items": { "type": "object" } }
        }
      },
      "FlowList": {
        "type": "object",
        "properties": { "flows": { "type": "array", "items": { "$ref": "#/components/schemas/Flow" } } }
      },
      "Flow": {
        "type": "object",
        "properties": {
          "flow_id": { "type": "string" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "latest": { "type": "integer", "description": "The latest published version number." },
          "deployments": { "type": "object", "description": "Live version per environment." }
        }
      },
      "CreateFlowRequest": {
        "type": "object",
        "required": ["slug", "name"],
        "properties": {
          "slug": { "type": "string", "description": "Lowercase letters, digits, hyphens." },
          "name": { "type": "string" }
        }
      },
      "CreateFlowResponse": {
        "type": "object",
        "properties": { "flow_id": { "type": "string" } }
      },
      "FlowImport": {
        "type": "object",
        "required": ["slug", "graph"],
        "properties": {
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "graph": { "type": "object", "description": "The flow graph (nodes + edges)." },
          "input_schema": { "type": "object" }
        }
      },
      "FlowImportResult": {
        "type": "object",
        "properties": {
          "flow_id": { "type": "string" },
          "slug": { "type": "string" },
          "version": { "type": "integer" },
          "created": { "type": "boolean" },
          "published": { "type": "boolean" }
        }
      },
      "FlowBundle": {
        "type": "object",
        "required": ["flows"],
        "properties": {
          "flows": { "type": "array", "items": { "$ref": "#/components/schemas/FlowImport" } }
        }
      },
      "FlowBundleResult": {
        "type": "object",
        "properties": {
          "results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "slug": { "type": "string" },
                "flow_id": { "type": "string" },
                "version": { "type": "integer" },
                "created": { "type": "boolean" },
                "published": { "type": "boolean" },
                "error": { "type": "string" }
              }
            }
          },
          "published": { "type": "integer" },
          "failed": { "type": "integer" },
          "unchanged": { "type": "integer" }
        }
      },
      "DeployRequest": {
        "type": "object",
        "required": ["environment", "version"],
        "properties": {
          "environment": { "type": "string", "enum": ["sandbox", "staging", "production"] },
          "version": { "type": "integer" },
          "challenger_version": { "type": "integer", "description": "Optional A/B challenger version." },
          "challenger_pct": { "type": "integer", "description": "Percent of traffic routed to the challenger." }
        }
      },
      "PromoteRequest": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "description": "Source environment whose live version is promoted." },
          "to": { "type": "string", "description": "Target environment." },
          "force": { "type": "boolean", "description": "Override the promotion gate where the stage allows it." }
        }
      },
      "PromoteResult": {
        "type": "object",
        "properties": {
          "promoted": { "type": "boolean", "description": "True when the version deployed directly." },
          "pending": { "type": "boolean", "description": "True when a maker-checker request was opened (production)." },
          "request_id": { "type": "string" },
          "version": { "type": "integer" }
        }
      },
      "Me": {
        "type": "object",
        "properties": {
          "org": { "type": "string" },
          "workspace": { "type": "string" },
          "actor": { "type": "string" },
          "scope": { "type": "string", "enum": ["sandbox", "production"] },
          "role": { "type": "string", "enum": ["viewer", "operator", "editor", "approver", "admin"] }
        }
      }
    }
  }
}
