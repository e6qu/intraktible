# Binaries & build output
/bin/
/dist/
# `go build ./cmd/intraktible` from the module root drops the executable here.
/intraktible
*.test
*.out
*.exe

# Go
/vendor/
coverage.out

# Node / SvelteKit (web/)
node_modules/
.svelte-kit/
web/build/
web/.svelte-kit/
web/node_modules/

# Playwright (web/)
web/playwright-report/
web/test-results/
web/.pw-data/
web/.pw-data-embedded/

# Generated embedded UI: `make web` overwrites platform/web/assets/ with the real
# SvelteKit build for a full artifact. Only the committed placeholder index.html is
# tracked (so `go build` always works); the build output is never committed.
/platform/web/assets/*
!/platform/web/assets/index.html
# A committed underscore-prefixed probe so the embed test proves //go:embed uses
# all: (a bare directive drops _app/ and ships a blank UI). make web wipes assets/,
# so this lives only in the placeholder tree the go-test stage builds against.
# Un-ignore the _app dir but only the probe inside it (not a real build's output).
!/platform/web/assets/_app/
/platform/web/assets/_app/*
!/platform/web/assets/_app/embed-probe.txt

# Local data / event log / databases
/data/
*.db
*.sqlite
*.sqlite3
*.badger/
*.wal

# Secrets / env
.env
.env.*
!.env.example

# Scratch / local-only working area (design screenshots, notes, throwaway scripts)
/temp/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# agent worktrees (transient)
.claude/worktrees/
