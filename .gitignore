# Binaries & build output
/bin/
/dist/
*.test
*.out
*.exe

# Go
/vendor/
coverage.out

# Node / SvelteKit (web/)
node_modules/
.svelte-kit/
web/build/
web/.svelte-kit/
web/node_modules/

# Playwright (web/)
web/playwright-report/
web/test-results/
web/.pw-data/

# Generated embedded UI: `make web` overwrites platform/web/assets/ with the real
# SvelteKit build for a full artifact. Only the committed placeholder index.html is
# tracked (so `go build` always works); the build output is never committed.
/platform/web/assets/*
!/platform/web/assets/index.html

# Local data / event log / databases
/data/
*.db
*.sqlite
*.sqlite3
*.badger/
*.wal

# Secrets / env
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
