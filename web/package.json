{
  "name": "intraktible-web",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:demo": "cd .. && make wasm demo-seed && cd web && BASE_PATH=/intraktible/demo VITE_DEMO=true vite build",
    "build:docs": "node scripts/build-docs.mjs",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:e2e": "env -u NO_COLOR NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" playwright test",
    "test:e2e:embedded": "env -u NO_COLOR NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" playwright test --config=playwright.embedded.config.ts",
    "review:screenshots": "env -u NO_COLOR NODE_OPTIONS=\"${NODE_OPTIONS:-} --disable-warning=DEP0205\" playwright test --config=playwright.screenshots.config.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "happy-dom": "^20.10.6",
    "marked": "^18.0.5",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.2",
    "svelte": "^5.1.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@xyflow/svelte": "^1.6.0"
  },
  "overrides": {
    "cookie": "^0.7.2"
  }
}
